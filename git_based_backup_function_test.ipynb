    "                os.mkdir(dst_path)\n",
    "                folders_to_fix.append( (src_path, dst_path) )\n",
    "    \n",
    "        shutil.copy2(Path(proj_dir)/name, Path(dst_dir)/name)\n",
    "    except Exception as e:\n",
    "        '''\n",
    "        The files that's tracked by git, but not exist in working tree\n",
    "        - Probably deleted file.\n",
    "        '''\n",
    "        with open(os.path.join(dst_dir,\"copy_failed_list.txt\"), \"a\") as f:\n",
    "            f.write(str(Path(proj_dir)/name) + \"\\n\")\n",
    "\n",
    "# copystat from bottom to top (from childest folder to the most parent folder to keep the edited time metadate as original)\n",
    "folders_to_fix.sort(key=lambda x: len(str(x[1])), reverse=True)\n",
    "\n",
    "for src_path, dst_path in folders_to_fix:\n",
