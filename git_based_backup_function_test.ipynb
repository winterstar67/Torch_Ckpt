    "Answer from gemini\n",
    "\n",
    "```\n",
    "from pathlib import Path\n",
    "import shutil\n",
    "\n",
    "def copy_with_relative_metadata(src_dir, dst_dir, file_list):\n",
    "    src_root = Path(src_dir).resolve()\n",
    "    dst_root = Path(dst_dir).resolve()\n",
    "\n",
    "    for file_path_str in file_list:\n",
    "        # 1. Create the absolute source path\n",
    "        src_file = src_root / file_path_str\n",
    "        \n",
    "        # 2. Create the absolute destination path\n",
    "        dst_file = dst_root / file_path_str\n",
    "        \n",
    "        # 3. Ensure the parent directories exist in the destination\n",
    "        # dst_file.parent is the directory containing the file\n",
    "        dst_file.parent.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "        # 4. Copy file + file metadata\n",
    "        shutil.copy2(src_file, dst_file)\n",
    "        \n",
    "        # 5. Optional: Sync folder metadata from src to dst\n",
    "        # We walk up from the file to the root to sync folder timestamps\n",
    "        for parent in src_file.parents:\n",
    "            if parent == src_root:\n",
    "                # Sync the root folder itself and stop\n",
    "                shutil.copystat(src_root, dst_root)\n",
    "                break\n",
    "            \n",
    "            # Get the folder path relative to project root\n",
    "            rel_folder = parent.relative_to(src_root)\n",
    "            shutil.copystat(parent, dst_root / rel_folder)\n",
    "```"
   ]
